# ── Database ───────────────────────────────────────────────────────────────────
# Async PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://observatorio:CHANGE_ME@localhost:5432/observatorio

# ── Cache ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── External APIs ──────────────────────────────────────────────────────────────
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2

# Portal da Transparência — get a free key at: https://portaldatransparencia.gov.br/api-de-dados
TRANSPARENCIA_API_KEY=

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production, set this to your exact frontend URL (e.g. https://meuapp.vercel.app).
# JSON array format: '["https://meuapp.vercel.app","https://www.meuapp.com.br"]'
CORS_ORIGINS=["http://localhost:3000"]
